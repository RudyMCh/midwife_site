{% extends 'admin/layouts/layout.html.twig' %}

{% block breadcrumb %}
    <li class="breadcrumb-item" aria-current="page">Médiathèque</li>
{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <form class="searchForm" method="GET">
        <input type="text" name="search" placeholder="Rechercher..." class="field" value="{{ search }}">
        <div class="icons-container">
            <div class="icon-search"></div>
            <div class="icon-close"><div class="x-up"></div><div class="x-down"></div></div>
        </div>
    </form>
    <span class="text-muted small">{{ files.getTotalItemCount }} fichier(s)</span>
</div>

<div class="row g-3">
    {% for file in files %}
    <div class="col-6 col-md-3 col-lg-2">
        <div class="card h-100">
            <div class="card-img-top d-flex align-items-center justify-content-center bg-light" style="height:120px;overflow:hidden">
                {% set ext = file.filename|split('.')|last|lower %}
                {% if ext in ['jpg','jpeg','png','gif','webp'] %}
                    <img src="/thumbs/{{ file.filename }}" alt="{{ file.alt }}"
                         style="max-height:120px;max-width:100%;object-fit:cover"
                         onerror="this.src='{{ asset('utils/no-picture.jpg') }}'">
                {% elseif ext in ['mp4','webm'] %}
                    <i class="fas fa-film fa-3x text-secondary"></i>
                {% elseif ext == 'pdf' %}
                    <i class="fas fa-file-pdf fa-3x text-danger"></i>
                {% else %}
                    <i class="fas fa-file fa-3x text-secondary"></i>
                {% endif %}
            </div>
            <div class="card-body p-2">
                <p class="card-text small text-truncate mb-1" title="{{ file.filename }}">{{ file.filename }}</p>
                {% if file.alt %}
                    <p class="card-text small text-muted text-truncate" title="{{ file.alt }}">{{ file.alt }}</p>
                {% endif %}
            </div>
            <div class="card-footer p-1 d-flex justify-content-end gap-1">
                <a href="{{ path('admin_media_file_edit', {'id': file.id}) }}" class="btn btn-sm btn-info">
                    <i class="fas fa-edit"></i>
                </a>
                <a href="#" data-bs-toggle="modal" data-bs-target="#deleteModal{{ file.id }}" class="btn btn-sm btn-danger">
                    <i class="fas fa-trash-alt"></i>
                </a>
            </div>
        </div>

        <div id="deleteModal{{ file.id }}" class="modal fade" role="dialog">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header d-flex justify-content-between">
                        <h5>Supprimer ce fichier</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p>Le fichier <strong>{{ file.filename }}</strong> sera supprimé du disque et de la base de données. Cette action est <strong>irréversible</strong>.</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                        <form action="{{ path('admin_media_file_delete', {'id': file.id}) }}" method="post">
                            <input type="hidden" name="_method" value="DELETE">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ file.id) }}">
                            <button class="btn btn-danger">Supprimer</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% else %}
    <div class="col-12">
        <p class="text-muted">Aucun fichier trouvé.</p>
    </div>
    {% endfor %}
</div>

<div class="aky-pagination mt-4">
    {{ knp_pagination_render(files) }}
</div>
{% endblock %}
