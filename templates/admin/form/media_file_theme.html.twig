{# Form theme for MediaFileType #}

{% block media_file_widget %}
    <div class="media-file-widget">
        {% if current_file %}
            <div class="media-file-preview mb-2">
                <img src="/thumbs/{{ current_file.filename }}"
                     alt="{{ current_file.alt ?? current_file.filename }}"
                     class="img-thumbnail"
                     style="max-height: 120px; max-width: 200px;">
                <div class="small text-muted mt-1">{{ current_file.filename }}</div>
            </div>
        {% endif %}

        {{ form_widget(form.existing_id) }}
        {{ form_widget(form.new_file) }}
        {{ form_errors(form.new_file) }}

        {% if image_hint is defined and image_hint %}
            <p class="image-hint">
                <i class="fas fa-circle-info" aria-hidden="true"></i>
                {{ image_hint.label }}
                {% if image_hint.width is defined and image_hint.height is defined %}
                    &mdash; {{ image_hint.width }}&thinsp;&times;&thinsp;{{ image_hint.height }}&thinsp;px minimum
                {% endif %}
                {% if image_hint.ratio is defined %}
                    ({{ image_hint.ratio }})
                {% endif %}
            </p>
            <p class="image-hint-feedback" role="alert" aria-live="polite"></p>
        {% endif %}
    </div>
{% endblock %}

{% block media_file_collection_widget %}
    <div class="media-file-collection"
         data-prototype="{{ form_widget(form.vars.prototype)|e('html_attr') }}">
        {% for item in form %}
            <div class="media-file-collection-item d-flex align-items-start gap-2 mb-2">
                {{ form_widget(item) }}
                <button type="button" class="btn btn-sm btn-outline-danger media-file-remove">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        {% endfor %}
    </div>
    <button type="button" class="btn btn-sm btn-outline-secondary media-file-add mt-2">
        <i class="fas fa-plus"></i> Ajouter
    </button>
{% endblock %}
