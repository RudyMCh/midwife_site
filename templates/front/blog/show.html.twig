{% extends 'front/layouts/layout.html.twig' %}

{% block preload %}
    {% if article.featuredImage %}
        <link rel="preload" as="image" href="{{ asset('uploads/' ~ article.featuredImage.path) }}" fetchpriority="high">
    {% endif %}
{% endblock %}

{% block og_type %}article{% endblock %}

{% block og_image %}
    {% if article.featuredImage %}
        <meta property="og:image" content="{{ absolute_url(asset('uploads/' ~ article.featuredImage.path)) }}">
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}
{% block twitter_image %}
    {% if article.featuredImage %}
        <meta name="twitter:image" content="{{ absolute_url(asset('uploads/' ~ article.featuredImage.path)) }}">
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}

{% block json_ld %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ article.title|json_encode|raw }},
  "url": {{ (app.request.schemeAndHttpHost ~ app.request.pathInfo)|json_encode|raw }},
  {% if article.featuredImage %}
  "image": {{ absolute_url(asset('uploads/' ~ article.featuredImage.path))|json_encode|raw }},
  {% endif %}
  {% if article.publishedAt %}
  "datePublished": {{ article.publishedAt|date('c')|json_encode|raw }},
  {% endif %}
  "dateModified": {{ article.updatedAt|date('c')|json_encode|raw }},
  {% if article.author %}
  "author": {
    "@type": "Person",
    "name": {{ (article.author.firstname ~ ' ' ~ article.author.lastname)|json_encode|raw }}
  },
  {% endif %}
  "publisher": {
    "@type": "MedicalOrganization",
    "name": "Cabinet de sages-femmes Quetigny",
    "medicalSpecialty": "Midwifery"
  }
}
</script>
{% endblock %}

{% block content %}
    <article class="blog-article">

        {# Hero avec image à la une #}
        <header class="blog-article__header">
            {% if article.featuredImage %}
                <div class="blog-article__hero"
                     style="background-image: url('{{ asset('uploads/' ~ article.featuredImage.path) }}')">
                    <div class="overlay"></div>
                    <div class="blog-article__hero-content">
                        <h1 class="blog-article__title">{{ article.title }}</h1>
                        <div class="blog-article__meta">
                            {% if article.publishedAt %}
                                <time datetime="{{ article.publishedAt|date('Y-m-d') }}">
                                    <i class="fas fa-calendar-alt" aria-hidden="true"></i>
                                    {{ article.publishedAt|date('d/m/Y') }}
                                </time>
                            {% endif %}
                            {% if article.author %}
                                <span class="blog-article__author">
                                    <i class="fas fa-user-circle" aria-hidden="true"></i>
                                    {{ article.author.firstname }} {{ article.author.lastname }}
                                </span>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="blog-article__hero blog-article__hero--no-image">
                    <div class="container">
                        <h1 class="blog-article__title">{{ article.title }}</h1>
                        <div class="blog-article__meta">
                            {% if article.publishedAt %}
                                <time datetime="{{ article.publishedAt|date('Y-m-d') }}">
                                    <i class="fas fa-calendar-alt" aria-hidden="true"></i>
                                    {{ article.publishedAt|date('d/m/Y') }}
                                </time>
                            {% endif %}
                            {% if article.author %}
                                <span class="blog-article__author">
                                    <i class="fas fa-user-circle" aria-hidden="true"></i>
                                    {{ article.author.firstname }} {{ article.author.lastname }}
                                </span>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endif %}
        </header>

        {# Corps de l'article #}
        <div class="blog-article__body">
            <div class="container">
                <div class="blog-article__content">
                    {{ article.content|raw }}
                </div>

                {# Carte auteure #}
                {% if article.author %}
                    <aside class="blog-article__author-card module">
                        {% if article.author.pictureSelf %}
                            <img src="{{ asset('uploads/' ~ article.author.pictureSelf.path) }}"
                                 alt="Photo de {{ article.author.firstname }} {{ article.author.lastname }}"
                                 class="blog-article__author-photo"
                                 width="80" height="80"
                                 loading="lazy">
                        {% endif %}
                        <div>
                            <p class="blog-article__author-name">
                                {{ article.author.firstname }} {{ article.author.lastname }}
                            </p>
                            {% if article.author.aboutMe %}
                                <p class="blog-article__author-bio">{{ article.author.aboutMe|striptags|truncate(200, '…') }}</p>
                            {% endif %}
                            <a href="{{ path('midwife_show', {'slug': article.author.slug}) }}" class="btn-link">
                                Voir son profil
                            </a>
                        </div>
                    </aside>
                {% endif %}

                {# Navigation #}
                <nav class="blog-article__nav" aria-label="Navigation articles">
                    <a href="{{ path('blog_index') }}" class="btn-link">
                        <i class="fas fa-arrow-left" aria-hidden="true"></i> Retour au blog
                    </a>
                </nav>
            </div>
        </div>

    </article>
{% endblock %}
