{% extends 'front/layouts/layout.html.twig' %}

{% block content %}
    {% set style = homepage.titleBg is not null ? 'background-image:url("'~getRelativePathFromValue(homepage.titleBg.id) ~'")' : 'background-color : red' %}
    <div class="title" style="{{ style }}">
        <h1>{{ office.name }}</h1>
        <div class="overlay-light"></div>
    </div>
    <section id="catchphrase" class="container">
        <div class="d-flex justify-content-center">
            {{ homepage.catchphrase }}
        </div>
    </section>
    <section id="team">
        <div class="container">
            <div class="d-flex justify-content-center align-items-center">
                <h2>Notre équipe</h2>
            </div>
        </div>
        <div class="container-fluid">
            <div class="midwives-card">

        {% for midwife in midwives %}
            {% include 'front/components/midwife-card.html.twig' %}
        {% endfor %}
            </div>
        </div>
    </section>
    <section id="services">
        <div class="container">
            <div class="d-flex justify-content-center align-items-center">
                <h2>Nos prestations</h2>
            </div>
        </div>
        <div class="container-fluid">
            <div class="domains-card">
                {% for domain in domains %}
                        <div class="domain-card module">
                            <div class="domain-card-header">
                                <div class="domain-card-header-logo">
                                    <i class="fas fa-baby fa-3x"></i>
                                </div>
                                <a href="{{ path('domain_show', {'slug':domain.slug}) }}" class="domains-card-title"><h4 class="text-center py-3">{{ domain.name }}</h4></a>

                            </div>
                            <ul>
                                {% for service in domain.services|sort((a,b)=> a.position <=> b.position) %}
                                    <li><a href="{{ path('domain_show', {'slug':domain.slug, '_fragment': service.slug}) }}">{{ service.name }}</a></li>
                                {% endfor %}
                            </ul>
                        </div>
                {% endfor %}
            </div>

        </div>

    </section>
    <section id="office">
        <div class="container">
            <div id="officeCarousel" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner">
                    {% for picture in homepage.pictures %}
                        <div class="carousel-item {{ loop.index is same as(1)? 'active' : '' }}">
                            <img src="{{ picture }}" class="d-block w-100" alt="{{ picture.alt }}">
                        </div>
                    {% endfor %}

                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#officeCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#officeCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            </div>
        </div>
    </section>
    <section id="map">
        <div class="container">
            <div class="d-flex justify-content-center align-items-center">
                <h2 class="text-center">Se rendre au cabinet de sage-femme?</h2>
            </div>
        </div>
        <div id="wazeBtn">
            <a href="https://waze.com/ul?q={{ (office.address~' '~office.zipcode~ ' '~office.city)|url_encode }}?ll={{ office.latitude }},-{{ office.longitude }}&navigate=yes" class="btn waze"></a>
        </div>
        <iframe src="{{ office.urlGoogleMap }}"></iframe>
    </section>
{% endblock %}