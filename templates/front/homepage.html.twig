{% extends 'front/layouts/layout.html.twig' %}

{% block preload %}
    {% if homepage.titleBg %}
        <link rel="preload" as="image" href="{{ media_path(homepage.titleBg) }}" fetchpriority="high">
    {% endif %}
{% endblock %}

{% block og_image %}
    {% if homepage.titleBg %}
        <meta property="og:image" content="{{ absolute_url(media_path(homepage.titleBg)) }}">
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}
{% block twitter_image %}
    {% if homepage.titleBg %}
        <meta name="twitter:image" content="{{ absolute_url(media_path(homepage.titleBg)) }}">
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}

{% block json_ld %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "MedicalOrganization",
  "name": {{ office.name|json_encode|raw }},
  "medicalSpecialty": "Midwifery",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": {{ office.address|default('')|json_encode|raw }},
    "postalCode": {{ office.zipcode|json_encode|raw }},
    "addressLocality": {{ office.city|json_encode|raw }},
    "addressCountry": "FR"
  },
  {% if office.phone %}"telephone": {{ office.phone|json_encode|raw }},{% endif %}
  {% if office.latitude and office.longitude %}
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": {{ office.latitude|json_encode|raw }},
    "longitude": {{ office.longitude|json_encode|raw }}
  },
  {% endif %}
  "employee": [
    {% for midwife in midwives %}
    {
      "@type": "Physician",
      "name": {{ (midwife.firstname ~ ' ' ~ midwife.lastname)|json_encode|raw }},
      "jobTitle": "Sage-femme",
      "url": {{ url('midwife_show', {'slug': midwife.slug})|json_encode|raw }}
    }{{ not loop.last ? ',' : '' }}
    {% endfor %}
  ]
}
</script>
{% endblock %}

{% block content %}
    {% set style = homepage.titleBg is not null ? 'background-image:url("'~media_path(homepage.titleBg) ~'")' : 'background-color : red' %}
    <div class="title" style="{{ style }}">
        <h1>{{ office.name }}</h1>
        <div class="overlay-light"></div>
    </div>
    <section id="catchphrase" class="container">
        <div class="d-flex justify-content-center">
            {{ homepage.catchphrase }}
        </div>
    </section>
    <section id="team">
        <div class="container">
            <div class="d-flex justify-content-center align-items-center">
                <h2>Notre équipe</h2>
            </div>
        </div>
        <div class="container-fluid">
            <div class="midwives-card">

        {% for midwife in midwives %}
            {% if midwife.slug %}
                {% include 'front/components/midwife-card.html.twig' %}
            {% endif %}
        {% endfor %}
            </div>
        </div>
    </section>
    <section id="services">
        <div class="container">
            <div class="d-flex justify-content-center align-items-center">
                <h2>Nos prestations</h2>
            </div>
        </div>
        <div class="container-fluid">
            <div class="domains-card">
                {% for domain in domains %}
                        <div class="domain-card module">
                            <div class="domain-card-header">
                                <div class="domain-card-header-logo">
                                    <i class="fas fa-baby fa-3x" aria-hidden="true"></i>
                                </div>
                                <a href="{{ path('domain_show', {'slug':domain.slug}) }}" class="domains-card-title"><h3 class="text-center py-3">{{ domain.name }}</h3></a>

                            </div>
                            <ul>
                                {% for service in domain.services|sort((a,b)=> a.position <=> b.position) %}
                                    <li><a href="{{ path('domain_show', {'slug':domain.slug, '_fragment': service.slug}) }}">{{ service.name }}</a></li>
                                {% endfor %}
                            </ul>
                        </div>
                {% endfor %}
            </div>

        </div>

    </section>
    <section id="office">
        <div class="container">
            <div id="officeCarousel" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner">
                    {% for picture in homepage.pictures %}
                        <div class="carousel-item {{ loop.index is same as(1)? 'active' : '' }}">
                            <img src="{{ media_path(picture) }}" class="d-block w-100" alt="{{ picture.alt ?? 'Photo du cabinet' }}" loading="lazy">
                        </div>
                    {% endfor %}

                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#officeCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#officeCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            </div>
        </div>
    </section>
    <section id="map">
        <div class="container">
            <div class="d-flex justify-content-center align-items-center">
                <h2 class="text-center">Se rendre au cabinet de sage-femme?</h2>
            </div>
        </div>
        <div id="wazeBtn">
            <a href="https://waze.com/ul?q={{ (office.address~' '~office.zipcode~ ' '~office.city)|url_encode }}?ll={{ office.latitude }},-{{ office.longitude }}&navigate=yes" class="btn waze" aria-label="Ouvrir dans Waze"></a>
        </div>
        <iframe
            src="https://maps.google.com/maps?q={{ (office.address~' '~office.zipcode~' '~office.city)|url_encode }}&output=embed"
            title="Plan d'accès au cabinet"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade">
        </iframe>
    </section>
{% endblock %}