{% extends 'front/layouts/layout.html.twig' %}

{% block preload %}
    {% if midwife.bgTitle %}
        <link rel="preload" as="image" href="{{ media_path(midwife.bgTitle) }}" fetchpriority="high">
    {% endif %}
{% endblock %}

{% block og_type %}profile{% endblock %}

{% block og_image %}
    {% if midwife.pictureSelf %}
        <meta property="og:image" content="{{ absolute_url(media_path(midwife.pictureSelf)) }}">
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}
{% block twitter_image %}
    {% if midwife.pictureSelf %}
        <meta name="twitter:image" content="{{ absolute_url(media_path(midwife.pictureSelf)) }}">
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}

{% block json_ld %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Physician",
  "name": {{ (midwife.firstname ~ ' ' ~ midwife.lastname)|json_encode|raw }},
  "jobTitle": "Sage-femme",
  "medicalSpecialty": "Midwifery",
  "url": {{ app.request.uri|json_encode|raw }},
  {% if midwife.email %}"email": {{ midwife.email|json_encode|raw }},{% endif %}
  {% if midwife.phone %}"telephone": {{ midwife.phone|json_encode|raw }},{% endif %}
  {% if midwife.rpps %}"identifier": [{"@type": "PropertyValue", "name": "RPPS", "value": {{ midwife.rpps|json_encode|raw }}}, {% if midwife.adeli %}{"@type": "PropertyValue", "name": "ADELI", "value": {{ midwife.adeli|json_encode|raw }}}{% endif %}],{% endif %}
  {% if midwife.siret %}"taxID": {{ midwife.siret|json_encode|raw }},{% endif %}
  {% if midwife.doctolibUrl %}"sameAs": {{ midwife.doctolibUrl|json_encode|raw }},{% endif %}
  "worksFor": {
    "@type": "MedicalOrganization",
    "name": "Cabinet de sages-femmes Quetigny",
    "medicalSpecialty": "Midwifery"
  }
}
</script>
{% endblock %}

{% block content %}
    {% set style = midwife.bgTitle is not null ? 'background-image:url("'~media_path(midwife.bgTitle) ~'")' : 'background-color : '~ midwife.backgroundColor1 %}

    <div class="title" style="{{ style }}">
        <h1>{{ midwife.firstname }} {{ midwife.lastname }}</h1>
       <div class="overlay"></div>
    </div>
    <section id="midwife">
        <div class="container">
            <div class="row">
                <div class="col-lg-6">
                    <img src="{{ media_path(midwife.pictureSelf) }}" alt="Photo de {{ midwife.firstname }} {{ midwife.lastname }}, sage-femme" loading="lazy">
                </div>
                <div class="col-lg-6 midwife-description">
                    {{ midwife.description|raw }}
                </div>
            </div>
        </div>
    </section>
    <section id="contact">
        <div class="container">
            <div class="d-flex justify-content-center align-items-center">
                <h2>Me contacter</h2>
            </div>
            <div class="midwife-contact">
                <a href="tel:{{ midwife.phone }}" class="btn-phone">
                    <i class="fas fa-phone" aria-hidden="true"></i>
                    <span>{{ midwife.phone|mobilePhone }}</span>
                </a>
                {% include 'front/components/doctolib.html.twig' %}
            </div>
            {% set shareUrl = app.request.schemeAndHttpHost ~ app.request.pathInfo %}
            <div class="midwife-share">
                <span>Partager :</span>
                <a href="https://www.facebook.com/sharer/sharer.php?u={{ shareUrl|url_encode }}"
                   class="share-facebook"
                   target="_blank"
                   rel="noopener noreferrer"
                   aria-label="Partager la fiche de {{ midwife.firstname }} {{ midwife.lastname }} sur Facebook">
                    <i class="fab fa-facebook-f" aria-hidden="true"></i>
                </a>
                <a href="https://wa.me/?text={{ (midwife.firstname ~ ' ' ~ midwife.lastname ~ ', sage-femme — ' ~ shareUrl)|url_encode }}"
                   class="share-whatsapp"
                   target="_blank"
                   rel="noopener noreferrer"
                   aria-label="Partager la fiche de {{ midwife.firstname }} {{ midwife.lastname }} sur WhatsApp">
                    <i class="fab fa-whatsapp" aria-hidden="true"></i>
                </a>
            </div>
        </div>
    </section>
    <section id="services">
        <div class="container">
            <div class="d-flex justify-content-center align-items-center">
                <h2>Mes prestations</h2>
            </div>
        </div>
        <div class="container-fluid">
            <div class="domains-card">
                {% for domain in domains %}
                    <div class="domain-card">
                        <div class="domain-card-header">
                            <div class="domain-card-header-logo">
                                <i class="fas fa-baby fa-3x" aria-hidden="true"></i>
                            </div>
                            <h3 class="text-center py-3">{{ domain.name }}</h3>
                        </div>
                        <ul>
                            {% for service in domain.services|filter(a=> a in midwife.services) %}
                                <li><a href="{{ path('domain_show', {'slug':domain.slug, '_fragment':service.slug}) }}">{{ service.name }}</a></li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>
    <section id="midwife-carousel">
        <div class="container">
            <div id="midwifeCarousel" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner">
                    {% for picture in midwife.pictures %}
                        <div class="carousel-item {{ loop.index is same as(1)? 'active' : '' }}">
                            <img src="{{ media_path(picture) }}" class="midwife-carousel-picture" alt="{{ picture.alt ?? 'Photo de ' ~ midwife.firstname ~ ' ' ~ midwife.lastname }}" loading="lazy">
                        </div>
                    {% endfor %}

                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#midwifeCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#midwifeCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            </div>
        </div>
    </section>
    <section id="path">
        <div class="container">
            <div class="d-flex justify-content-center align-items-center flex-column">
                <h2>Mon parcours professionnel</h2>
                <ul>
                    {% for path in midwife.paths %}
                        <li>
                            <i class="fas fa-user-nurse" aria-hidden="true"></i>
                            {{ path.title }} — {{ path.city }} — {{ path.start }} – {{ path.end }}
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </section>
    <section id="degree">
        <div class="container">
            <div class="d-flex justify-content-center align-items-center flex-column">
                <h2>Mes diplômes</h2>
            <ul>
                {% for degree in midwife.degrees %}
                    <li>
                        <i class="fas fa-graduation-cap" aria-hidden="true"></i>
                        {{ degree.title }} — {{ degree.establishment }} — {{ degree.year }}
                    </li>
                {% endfor %}
            </ul>
            </div>
        </div>
    </section>
{% endblock %}


