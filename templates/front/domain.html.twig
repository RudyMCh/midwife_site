{% extends 'front/layouts/layout.html.twig' %}

{% block content %}
    {% set style = domain.titleBg is not null ? 'background-image:url("'~media_path(domain.titleBg) ~'")' : 'background-color : '~domain.titleColorBg %}
    <div class="title" style="{{ style }}">
        <h1>{{ domain.name }}</h1>
        <div class="overlay"></div>
    </div>
    {% for service in domain.services|sort((a,b)=> a.position <=>b.position) %}
        <div class="domain-service">
            <section id="{{ service.slug }}" class="module">
                <div class="container">
                    <div class="domain-service-container-{{ loop.index is even? 'even' : 'odd' }}">
                            <div class="col-lg-6 d-flex justify-content-center align-items-center">
                                {% if service.picture is not null %}
                                    {{ media_render(service.picture, 'domain-iframe') }}
                                {% endif %}
                            </div>
                            {% include 'front/components/service-description.html.twig' %}

                    </div>
                </div>
            </section>
        </div>
    {% endfor %}
{% endblock %}