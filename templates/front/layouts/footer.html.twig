{% set office = getOffice() %}

<footer class="footer-main text-white">
    <div class="container">
        <div class="row py-5">

            {# ── Colonne 1 : Cabinet ─────────────────────────────────────── #}
            <div class="col-md-4 footer-column">
                {% if office %}
                    <h3 class="footer-section-title">{{ office.name }}</h3>
                    <ul class="footer-info-list">
                        {% if office.address %}
                            <li>
                                <i class="fas fa-map-marker-alt footer-icon" aria-hidden="true"></i>
                                <span>{{ office.address }}<br>{{ office.zipcode }} {{ office.city }}</span>
                            </li>
                        {% endif %}
                        {% if office.phone %}
                            <li>
                                <i class="fas fa-phone footer-icon" aria-hidden="true"></i>
                                <a href="tel:{{ office.phone }}">{{ office.phone|mobilePhone }}</a>
                            </li>
                        {% endif %}
                        <li>
                            <i class="fas fa-clock footer-icon" aria-hidden="true"></i>
                            <span>Lun – Ven : 8h – 19h<br>Sam : 8h – 12h</span>
                        </li>
                    </ul>
                {% endif %}
            </div>

            {# ── Colonne 2 : Navigation ──────────────────────────────────── #}
            <div class="col-md-4 footer-column">
                <h3 class="footer-section-title">Navigation</h3>
                <ul class="footer-nav-list">
                    <li><a href="{{ path('homepage_homepage') }}">Accueil</a></li>
                    {% for domain in getDomains() %}
                        <li><a href="{{ path('domain_show', {'slug': domain.slug}) }}">{{ domain.name }}</a></li>
                    {% endfor %}
                    <li><a href="{{ path('informations_utiles') }}">Infos utiles</a></li>
                </ul>
            </div>

            {# ── Colonne 3 : Sages-femmes ────────────────────────────────── #}
            <div class="col-md-4 footer-column">
                <h3 class="footer-section-title">Nos sages-femmes</h3>
                <div class="footer-midwife-list">
                    {% for midwife in getMidwives() %}
                        <div class="footer-midwife">
                            <a href="{{ path('midwife_show', {'slug': midwife.slug}) }}" class="footer-midwife-name">
                                {{ midwife.firstname }} {{ midwife.lastname }}
                            </a>
                            <div class="footer-midwife-contact">
                                {% if midwife.phone %}
                                    <a href="tel:{{ midwife.phone }}">
                                        <i class="fas fa-phone" aria-hidden="true"></i> {{ midwife.phone|mobilePhone }}
                                    </a>
                                {% endif %}
                                {% if midwife.email %}
                                    <a href="mailto:{{ midwife.email }}">
                                        <i class="far fa-envelope" aria-hidden="true"></i> {{ midwife.email }}
                                    </a>
                                {% endif %}
                                {% if midwife.doctolibUrl %}
                                    {% include 'front/components/doctolib-mini.html.twig' with {'midwife': midwife} %}
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>

        </div>{# /row #}
    </div>{# /container #}

    {# ── Barre inférieure ────────────────────────────────────────────────── #}
    <div class="footer-bottom">
        <div class="container">
            <div class="footer-bottom-inner">
                <span>© {{ date('now')|date('Y') }} {{ office ? office.name : 'Cabinet Albandea-Gauthier' }}</span>
                <a href="{{ path('informations_utiles') }}">Mentions légales</a>
            </div>
        </div>
    </div>

</footer>
