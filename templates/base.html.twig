<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=0">

        <title>{% block title %}{{ meta_title is defined and meta_title ? meta_title : 'Sages-femmes Quetigny' }}{% endblock %}</title>

        <meta name="description" content="{% block meta_description %}{{ meta_description is defined and meta_description ? meta_description : '' }}{% endblock %}">
        <meta name="robots" content="{% block robots %}INDEX, FOLLOW{% endblock %}">

        {% block canonical %}
            <link rel="canonical" href="{{ app.request.uri }}">
        {% endblock %}

        {# Open Graph #}
        <meta property="og:type" content="{% block og_type %}website{% endblock %}">
        <meta property="og:locale" content="fr_FR">
        <meta property="og:title" content="{% block og_title %}{{ meta_title is defined and meta_title ? meta_title : 'Sages-femmes Quetigny' }}{% endblock %}">
        <meta property="og:description" content="{% block og_description %}{{ meta_description is defined and meta_description ? meta_description : '' }}{% endblock %}">
        <meta property="og:url" content="{{ app.request.uri }}">
        {% block og_image %}{% endblock %}

        {# Favicons #}
        <link rel="shortcut icon" type="image/png" href="{{ asset('favicon/favicon.ico') }}"/>
        <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('favicon/apple-touch-icon.png') }}">
        <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('favicon/favicon-32x32.png') }}">
        <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('favicon/favicon-16x16.png') }}">

        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.7.2/css/all.min.css">
        <link rel="stylesheet" href="{{ asset('styles/front.scss') }}">
        {% block stylesheets %}{% endblock %}

        <script type="text/javascript" src="{{ asset('tarteaucitron/tarteaucitron.js') }}"></script>
        <script type="text/javascript">
            tarteaucitron.init({
                "privacyUrl": "",
                "hashtag": "#tarteaucitron",
                "cookieName": "tarteaucitron",
                "orientation": "middle",
                "groupServices": false,
                "showAlertSmall": false,
                "cookieslist": false,
                "closePopup": false,
                "showIcon": true,
                "iconPosition": "BottomRight",
                "adblocker": false,
                "DenyAllCta" : true,
                "AcceptAllCta" : true,
                "highPrivacy": true,
                "handleBrowserDNTRequest": false,
                "removeCredit": false,
                "moreInfoLink": true,
                "useExternalCss": false,
                "useExternalJs": false,
                "readmoreLink": "",
                "mandatory": true,
            });
        </script>

        {% block json_ld %}{% endblock %}

        {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% block javascripts %}{% endblock %}
    </head>
    <body>
        {% block body %}{% endblock %}
    </body>
</html>
