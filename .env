# Valeurs par défaut. Ne pas mettre de secrets de production ici.
# Utiliser .env.local (non commité) pour les surcharges locales.
#
# Fichiers chargés par ordre de priorité croissante :
#   .env < .env.local < .env.$APP_ENV < .env.$APP_ENV.local

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_in_env_local
###< symfony/framework-bundle ###

###> symfony/mailer ###
MAILER_DSN=smtp://mailer:1025
###< symfony/mailer ###

###> doctrine/doctrine-bundle ###
# Variables MariaDB (utilisées par docker-compose.yml et DATABASE_URL)
MYSQL_DATABASE=sagefemme
MYSQL_USER=sagefemme
MYSQL_PASSWORD=sagefemme
MYSQL_ROOT_PASSWORD=root

DATABASE_URL="mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@database:3306/${MYSQL_DATABASE}?serverVersion=mariadb-11.4.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###
